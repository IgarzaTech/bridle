{
  "name": "@nexopay/bridle",
  "version": "0.1.0",
  "description": "Per-agent budget guardrail for agentic payments — el presupuesto que bloquea de verdad. Framework-agnostic, storage-pluggable, x402-ready.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgarzaTech/bridle.git"
  },
  "bugs": {
    "url": "https://github.com/IgarzaTech/bridle/issues"
  },
  "homepage": "https://github.com/IgarzaTech/bridle#readme",
  "keywords": [
    "agentic-payments",
    "budget",
    "guardrail",
    "x402",
    "rate-limit",
    "spend-control"
  ],
  "engines": {
    "node": "20.x",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "default": "./dist/postgres/index.js"
    },
    "./x402": {
      "types": "./dist/x402/index.d.ts",
      "default": "./dist/x402/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:example": "pnpm --filter @nexopay/bridle-example build",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:example": "pnpm --filter @nexopay/bridle-example lint",
    "test": "jest --passWithNoTests",
    "demo": "pnpm --filter @nexopay/bridle-example demo",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.8.0"
  },
  "peerDependencies": {
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.1",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "pg": "^8.21.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
